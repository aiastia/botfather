# ============================================
# TG Bot 托管 & 私聊助手平台 配置文件
# ============================================

# 主Bot Token（从 @BotFather 获取）
MASTER_BOT_TOKEN=your_master_bot_token_here

# 运行模式: polling / webhook
BOT_MODE=polling

# Webhook 配置（仅 webhook 模式需要）
WEBHOOK_HOST=https://your-domain.com
WEBHOOK_PORT=8443
WEBHOOK_PATH=/webhook

# 数据库配置
# 数据库类型: sqlite / mysql
DB_TYPE=sqlite
# SQLite 数据库文件路径
DB_SQLITE_PATH=./data/bot_platform.db
# MySQL 配置（仅 mysql 模式需要）
DB_MYSQL_HOST=localhost
DB_MYSQL_PORT=3306
DB_MYSQL_USER=root
DB_MYSQL_PASSWORD=
DB_MYSQL_DATABASE=bot_platform

# AI 配置（OpenAI 兼容接口）
AI_API_KEY=your_openai_api_key_here
AI_API_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-3.5-turbo
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO