# ============================================
# TG Bot 托管 & 私聊助手平台 配置文件
# ============================================

# 主Bot Token（从 @BotFather 获取）
MASTER_BOT_TOKEN=your_master_bot_token_here

# 管理员 Telegram User ID（逗号分隔）
# 获取方法：向 @userinfobot 发消息获取你的 ID
ADMIN_IDS=your_telegram_user_id

# 运行模式: polling / webhook
BOT_MODE=polling

# ==================== Webhook 配置 ====================
# 仅 BOT_MODE=webhook 时需要配置

# 外部可访问的 HTTPS 地址
# 这是你的 Nginx 反代后的完整域名，Telegram 会往这个地址推送消息
WEBHOOK_HOST=https://your-domain.com

# 容器内部监听端口（Docker 会暴露这个端口到宿主机）
# 你的 Nginx 应该反代到 127.0.0.1:8081（即这个端口）
# 一般不需要修改
WEBHOOK_PORT=8081

# Webhook 基础路径
WEBHOOK_PATH=/webhook

# Webhook 密钥（强烈建议设置）
# 用于验证请求确实来自 Telegram，防止伪造请求
# 设置方法：先在终端运行以下命令生成随机字符串：
#   openssl rand -hex 32
# 然后把输出的字符串粘贴到这里，例如：
#   WEBHOOK_SECRET=a1b2c3d4e5f6...
WEBHOOK_SECRET=

# 数据库配置
# 数据库类型: sqlite / mysql
DB_TYPE=sqlite
# SQLite 数据库文件路径
DB_SQLITE_PATH=./data/bot_platform.db
# MySQL 配置（仅 mysql 模式需要）
DB_MYSQL_HOST=localhost
DB_MYSQL_PORT=3306
DB_MYSQL_USER=root
DB_MYSQL_PASSWORD=
DB_MYSQL_DATABASE=bot_platform

# AI 配置（OpenAI 兼容接口）
AI_API_KEY=your_openai_api_key_here
AI_API_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-3.5-turbo
AI_TEMPERATURE=1.0
AI_MAX_TOKENS=2000

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO